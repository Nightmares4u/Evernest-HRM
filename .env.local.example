# Supabase - get from your Supabase project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_or_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Cron secret - generate any random long string
CRON_SECRET=replace_with_random_secret

# App config
NEXT_PUBLIC_APP_NAME=EN HRM
TZ=Asia/Karachi

# App URL — used in email links. Set to https://your-vercel-domain.vercel.app for production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email notifications via Resend (optional — leave blank to disable email sends)
# Sign up at resend.com (free: 100/day, 3000/month).
# 1. Create an API key, paste it here.
# 2. To send to staff (not just yourself): verify a domain in Resend, then set
#    EMAIL_FROM to e.g. "EN HRM <hrm@evernestconsultants.com>".
#    Until you verify a domain, only your own verified email will receive
#    using the default `onboarding@resend.dev` sender.
RESEND_API_KEY=
EMAIL_FROM=

# Gemini — powers the internal CRM Assistant at /crm/assistant.
# Get an API key from Google AI Studio: https://aistudio.google.com/apikey
# Leave GEMINI_API_KEY blank to disable the assistant (page renders a notice).
# GEMINI_MODEL is optional; defaults to gemini-2.5-flash if unset.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
