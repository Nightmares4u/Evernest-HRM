# Supabase — get from your Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Cron secret — generate any random long string. Used to protect /api/cron/* routes.
CRON_SECRET=replace-with-long-random-string

# App config
NEXT_PUBLIC_APP_NAME=EN HRM
TZ=Asia/Karachi
